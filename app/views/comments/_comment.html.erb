<tr id="comment_<%= comment.id %>">
  <div class="row align-items-center">
    <td  class="col-1 text-center">
      <%= image_tag comment.user.avatar_url, class: "rounded-circle user-avatar" %>
    </td>

    <td class="col-9">
      <h3 class="small"><%= comment.user.name %></h3>
      <p><%= simple_format(comment.body) %></p>
    </td>

    <% if current_user.own?(comment) %>
      <td class="action col-2">
        <ul class="list-inline justify-content-center" style="float: right;">
          <li class="list-inline-item">
            <%= link_to edit_comment_path(comment), class: "edit-comment-link" do %>
              <i class="bi bi-pencil-fill"></i>
            <% end %>
          </li>
          <li class="list-inline-item">
            <%= link_to comment_path(comment), class: "delete-comment-link", data: { turbo_method: :delete, turbo_confirm: t('messages.delete_confirmation') } do %>
              <i class="bi bi-trash-fill"></i>
            <% end %>
          </li>
        </ul>
      </td>
    <% end %>
  </div>
</tr>
