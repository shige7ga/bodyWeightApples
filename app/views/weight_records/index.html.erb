<h1><%= t('.title') %></h1>
<hr>

<% if @weight_records.any? %>
  <% @weight_records.each do |record| %>
    <div class="container">
      <div class="row align-items-center">
        <div class="col-2 text-center">
          <div class="mt-2 mb-3">
            <%= image_tag record.user.avatar_url, class: 'user-avatar rounded-circle border mb-3' %>
          </div>
        </div>
        <div class="col-8 ">
          <p>ユーザー名：<%= record.user.name %> | リンゴ体重：<%= record.decorate.apple_weight %>個分</p>
          <p>登録日時：<%= record.created_at.strftime("%Y/%m/%d %H:%M") %></p>
        </div>
        <div class="col-2 text-center">
          <%= link_to '詳細', weight_record_path(record), class: 'btn btn-primary' %>
        </div>
        <hr>
      </div>
    </div>
  <% end %>
<% else %>
  <p>体重の記録はありません。</p>
<% end %>
