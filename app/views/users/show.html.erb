<% content_for(:title, t('.title', user_name: @user.name)) %>
<h1><%= t ".title", user_name: @user.name %></h1>
<div class="container mt-4">
  <div class="row align-items-center">
    <div class="col-2 text-center">
      <div class="mt-2 mb-3">
        <%= image_tag @user.avatar_url, class: 'user-avatar rounded-circle border' %>
      </div>
    </div>
    <div class="col-8">
      <% if current_user?(@user) %>
        <p>メールアドレス：<%= @user.email %></p>
      <% end %>
      <p>身長：<%= @user.height ? "#{@user.height}" : " -- " %>cm</p>
      <p>理想リンゴ体重：<%= @user.decorate.ideal_apple_weight %>個（<%= @user.decorate.ideal_weight %>kg）</p>
    </div>
    <div class="col-2 text-center">
      <div>
        <% if current_user?(@user) %>
          <%= link_to t('.edit_btn'), edit_user_path(@user), class: 'btn btn-primary mb-1' %>
          <%= link_to t('.destroy_btn'), user_path(@user), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: 'btn btn-primary mb-1' %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<h2 class="mt-3">体重記録一覧</h2>
<hr>
<% if @user.weight_records.any? %>
  <% @user.weight_records.each do |record| %>
    <div class="row align-items-center">
      <div class="col-10">
        <p>リンゴ体重：<%= record.decorate.apple_weight %>個分</p>
        <p>登録日時：<%= record.created_at.strftime("%Y/%m/%d %H:%M") %></p>
      </div>
      <div class="col-2 text-center">
        <%= link_to '詳細', weight_record_path(record), class: 'btn btn-primary' %>
      </div>
    </div>
    <hr>
  <% end %>
<% else %>
  <p>体重の記録はありません。</p>
<% end %>
