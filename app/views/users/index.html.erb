<h1><%= t '.title' %></h1>
<hr>
<% @users.each do |user| %>
  <div class="container">
    <div class="row align-items-center">
      <div class="col-2 text-center">
        <%= image_tag user.avatar_url, class: 'user-avatar rounded-circle border' %>
      </div>
      <div class="col-10">
        <h2 class="fs-3 mb-3"><%= link_to user.name, user_path(user) %></h2>
        <p>＜リンゴ体重＞ 理想：<%= user.decorate.ideal_apple_weight %>個 ｜ 最新：<%= user.decorate.latest_apple_weight %></p>
      </div>
    </div>
  </div>
  <hr>
<% end %>
