<%= form_with model: weight_record do |f| %>
  <div class="mb-2">
    <%= f.label :weight, class: 'form-label' %>
    <%= f.number_field :weight, step: '0.1', class: 'form-control' %>
    <div class="form-text ms-2">
      ※体重は「kg」で、小数点1桁まで入力してください（例: 62.5）
    </div>
  </div>
  <div class="mb-2">
    <%= f.label :comment, class: 'form-label' %>
    <%= f.text_field :comment, class: 'form-control' %>
  </div>
  <%= f.submit class: 'btn btn-primary mb-3' %>
<% end %>
